# ──────────────────────────────────────────────────────────────────
# To-Do List Bot Gen 2 — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ──────────────────────────────────────────────────────────────────

# ═══ REQUIRED ════════════════════════════════════════════════════
# Your Discord bot token (from https://discord.com/developers)
DISCORD_TOKEN=your_discord_bot_token_here

# ═══ BOT SETTINGS ════════════════════════════════════════════════
# Prefix is NOT used — this bot is 100% slash-command based.
# Kept here only so the config parser doesn't error; leave as-is.
COMMAND_PREFIX=/

# Default timezone for new users
DEFAULT_TIMEZONE=Asia/Bangkok

# Default language: th | en
DEFAULT_LANG=th

# Comma-separated Discord user IDs with owner-level access
BOT_OWNER_IDS=

# ═══ DATABASE ════════════════════════════════════════════════════
# Path to the SQLite database file
DATABASE_PATH=data/tasks.db

# Connection pool size
DB_POOL_SIZE=5

# Query timeout in seconds
DB_TIMEOUT=30

# Enable automatic database backups
DB_BACKUP_ENABLED=true

# Backup interval in hours
DB_BACKUP_INTERVAL_HOURS=24

# Number of backup files to keep
DB_MAX_BACKUPS=7

# L1 QueryCache TTL in seconds (cached read results; 0 = disable)
DB_QUERY_CACHE_TTL=30.0

# BulkWriter flush interval in milliseconds (audit log batching)
DB_BULK_WRITE_INTERVAL_MS=500

# WAL checkpoint interval in hours (keeps WAL file size bounded)
DB_WAL_CHECKPOINT_HOURS=6

# ═══ RATE LIMITING ════════════════════════════════════════════════
# Max commands per minute per user before blocking
RATE_COMMANDS_PER_MIN=30

# Max tasks that can be created per hour per user
RATE_TASKS_PER_HOUR=100

# Max searches per minute per user
RATE_SEARCHES_PER_MIN=10

# Max CSV exports per day per user
RATE_EXPORTS_PER_DAY=5

# Duration (seconds) a user is blocked after exceeding a limit
RATE_BLOCK_SECONDS=300

# Input sanitization limits (characters)
MAX_INPUT_LENGTH=2000
MAX_TASK_NAME_LENGTH=200
MAX_DESCRIPTION_LENGTH=1000

# ═══ NOTIFICATIONS ════════════════════════════════════════════════
# How often (minutes) to check and send deadline reminders
REMINDER_INTERVAL_MIN=30

# How often (minutes) to check and renew recurring tasks
RECURRING_INTERVAL_MIN=60

# How often (hours) to re-notify about overdue tasks
OVERDUE_REMIND_HOURS=6

# Daily summary notification
DAILY_SUMMARY_ENABLED=true

# Hour (0-23) to send daily summary
DAILY_SUMMARY_HOUR=8

# How often (minutes) to check for deadline DM reminders
# The loop sends a DM to the task owner at ~24h / ~3h / ~1h before deadline
DM_REMINDER_INTERVAL_MIN=15

# ═══ KEEP-ALIVE WEB SERVER ═══════════════════════════════════════
# Async aiohttp server — runs on the bot's event loop (no daemon thread)
# Endpoints: GET /  GET /health  GET /ready  GET /metrics
WEBSERVER_ENABLED=true
WEBSERVER_HOST=0.0.0.0
WEBSERVER_PORT=8080
